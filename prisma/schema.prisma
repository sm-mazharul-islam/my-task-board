generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma" // Ensure this matches your path!
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int       @id @default(autoincrement())
  email    String    @unique
  name     String?
  projects Project[]
}

model Project {
  id          String  @id @default(uuid())
  title       String
  description String?
  userId      Int?
  user        User?   @relation(fields: [userId], references: [id])
  tasks       Task[]
}

model Task {
  id        String  @id @default(uuid())
  title     String
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
}
